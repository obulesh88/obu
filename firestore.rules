
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permissive rules for prototype development
    // Allows full read/write access to all collections used in the app
    
    match /{document=**} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }

    match /payout_requests/{requestId} {
      allow read, write: if true;
    }

    match /transactions/{transactionId} {
      allow read, write: if true;
    }

    match /wingo_results/{resultId} {
      allow read, write: if true;
    }

    match /k3_results/{resultId} {
      allow read, write: if true;
    }

    match /dragon_tiger_results/{resultId} {
      allow read, write: if true;
    }
  }
}
