
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile and wallet information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "memberId": { "type": "string", "description": "A user-friendly unique ID (e.g., OR-123456)." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "phoneNumber": { "type": "string", "description": "The user's phone number." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of account creation." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of the last update." },
        "profile": {
          "type": "object",
          "properties": {
            "displayName": { "type": "string" },
            "Uid": { "type": "string" }
          },
          "required": ["displayName", "Uid"]
        },
        "wallet": {
          "type": "object",
          "properties": {
            "balance": { "type": "number" }
          },
          "required": ["balance"]
        },
        "referral": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "count": { "type": "number" },
            "earnings": { "type": "number" }
          }
        },
        "bankDetails": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "contact": { "type": "string" },
            "email": { "type": "string" },
            "accountNumber": { "type": "string" },
            "ifsc": { "type": "string" },
            "vpa": { "type": "string" },
            "payoutType": { "type": "string", "enum": ["bank", "upi"] }
          }
        },
        "captcha": {
          "type": "object",
          "properties": {
            "is_active": { "type": "boolean" },
            "verifiedAt": { "type": ["string", "null"], "format": "date-time" },
            "claimed": { "type": "boolean" },
            "reward_comm": { "type": "number" }
          }
        },
        "watchAds": {
          "type": "object",
          "properties": {
            "ad_provider": { "type": "string" },
            "ad_start": { "type": ["string", "null"], "format": "date-time" },
            "verifiedAt": { "type": ["string", "null"], "format": "date-time" },
            "ad_completed": { "type": "boolean" },
            "reward_comm": { "type": "number" }
          }
        },
        "status": {
          "type": "object",
          "properties": {
            "status": { "type": "string" }
          }
        }
      },
      "required": ["uid", "memberId", "email", "phoneNumber", "createdAt", "profile", "wallet"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "A request from a user to withdraw their INR balance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"] },
        "payoutDetails": { 
          "type": "object",
          "properties": {
            "payoutType": { "type": "string", "enum": ["bank", "upi"] },
            "vpa": { "type": "string" },
            "accountNumber": { "type": "string" },
            "ifsc": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "payoutDetails", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of any balance change.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["INR"] },
        "type": { "type": "string", "enum": ["ad", "captcha", "game", "referral", "withdrawal"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "currency", "type", "createdAt"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores individual user profile data."
    },
    "/payout_requests/{requestId}": {
      "schema": { "$ref": "#/entities/WithdrawalRequest" },
      "description": "Manual payout requests for admin processing."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Log of all user transactions."
    }
  }
}
